public class TicTacToe {
        public static void main(String[] args) {
        char[][] board = new char[3][3];
        for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 3; j++) {
        board[i][j] = '-';
        }
        }
        System.out.println("Initial Tic-Tac-Toe Board:");

        for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 3; j++) {
        System.out.print(board[i][j] + " ");
        }
        System.out.println();
        }
        }
        }